---
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';
import PracticeCTA from '../components/PracticeCTA.astro';

const values = [
  {
    numeral: 'I.',
    title: 'Attentiveness',
    body: 'We stay fully present and engaged — listening to your concerns and shaping legal solutions around your unique situation.',
  },
  {
    numeral: 'II.',
    title: 'Relentless preparation',
    body: 'Every case is prepared as if it will be tried. That readiness is what creates leverage at the table.',
  },
  {
    numeral: 'III.',
    title: 'Straight answers',
    body: 'We tell you where you stand in plain language, so you can make decisions with confidence.',
  },
];
---

<BaseLayout title="About | Kagasoff Law Firm, A.P.C." active="About">
  <!-- ===== PAGE HERO ===== -->
  <section class="bg-navy text-paper">
    <div class="mx-auto max-w-[1180px] px-10 pb-[78px] pt-[74px]">
      <p class="mb-[22px] text-xs uppercase tracking-[0.36em] text-brasslight">About the Firm</p>
      <h1 class="max-w-[740px] font-serif text-[56px] font-medium leading-[1.08]">
        A small firm, by design — so your case never gets lost.
      </h1>
    </div>
  </section>

  <!-- ===== VISION ===== -->
  <section class="mx-auto grid max-w-[1180px] grid-cols-1 items-start gap-16 px-10 py-[78px] md:grid-cols-2">
    <div>
      <p class="mb-[18px] text-xs uppercase tracking-[0.3em] text-brass">Our Vision</p>
      <p class="mb-6 font-serif text-[27px] font-normal leading-[1.4] text-navy">
        To provide exceptional legal counsel and representation that exceeds our clients'
        expectations.
      </p>
      <p class="mb-[18px] text-[15.5px] font-light leading-[1.8] text-ink">
        Based in Westminster and serving clients throughout Orange County, the firm handles matters
        across seven practice areas — from personal injury and criminal defense to family law and
        professional licensing. What unites that range is a single approach: thorough preparation,
        plain-spoken advice, and direct access to the attorney working on your case.
      </p>
      <p class="text-[15.5px] font-light leading-[1.8] text-ink">
        A deliberate caseload means every client receives the attention their situation demands —
        whether that calls for a quiet negotiation or a fight in the courtroom.
      </p>
    </div>
    <Placeholder label="Firm / office photograph" class="min-h-[440px] rounded" />
  </section>

  <!-- ===== VALUES ===== -->
  <section class="bg-cream">
    <div class="mx-auto max-w-[1180px] px-10 py-[74px]">
      <h2 class="mb-[46px] text-center font-serif text-[38px] font-medium text-navy">
        What you can expect
      </h2>
      <div class="grid grid-cols-1 gap-10 md:grid-cols-3">
        {
          values.map((v) => (
            <div>
              <div class="mb-3 font-serif text-[30px] text-brass">{v.numeral}</div>
              <h3 class="mb-2.5 font-serif text-[23px] font-semibold text-navy">{v.title}</h3>
              <p class="text-[14.5px] font-light leading-[1.7] text-ink">{v.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== ATTORNEY ===== -->
  <section class="bg-navydark">
    <div class="mx-auto grid max-w-[1180px] grid-cols-1 md:grid-cols-[0.85fr_1.15fr]">
      <Placeholder label="Ashley Kagasoff portrait" dark class="min-h-[460px]" />
      <div class="px-14 py-[74px] text-paper">
        <p class="mb-[18px] text-xs uppercase tracking-[0.3em] text-brass">The Attorney</p>
        <h2 class="mb-1.5 font-serif text-[36px] font-medium">Ashley Kagasoff</h2>
        <div class="mb-[26px] text-[13px] tracking-[0.04em] text-brasslight">
          Attorney at Law · Founder
        </div>
        <p class="mb-4 text-[15px] font-light leading-[1.8] text-mist">
          Ashley has dedicated over 17 years to results-driven advocacy and personalized service.
          Her practice spans criminal defense, professional license defense, personal injury,
          employment, and family law — giving clients comprehensive solutions tailored to their
          needs.
        </p>
        <p class="mb-4 text-[15px] font-light leading-[1.8] text-mist">
          Having worked both sides of the law — as a law clerk for the Orange County District
          Attorney's and Public Defender's offices, then fifteen years in private defense — she
          brings a rare perspective to every matter. She has represented clients in state and
          federal court and before California licensing boards including the Medical, Nursing,
          Dental, Real Estate, and Contractors' boards, the State Bar, and the Commission on Teacher
          Credentialing, and has fought for millions in settlements for injured clients.
        </p>
        <p class="text-[15px] font-light leading-[1.8] text-mist">
          She earned her undergraduate degree from UCLA (2003) and her J.D. from Chapman University
          School of Law (2007). She is licensed in California and admitted to the Eastern, Central,
          and Southern District Courts.
        </p>
      </div>
    </div>
  </section>

  <PracticeCTA heading="Let's discuss your situation." sub="Your first consultation is free and confidential." />
</BaseLayout>
