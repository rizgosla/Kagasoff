---
/** Contact — navy hero, the consultation form (client-side validated, with a
    confirmation state), and the office info column with a map placeholder. */
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';
import { practiceAreas } from '../data/practiceAreas';

const matterOptions = [...practiceAreas.map((a) => a.name), 'Not sure / Other'];

const labelCls = 'mb-2 block text-xs uppercase tracking-[0.08em] text-ink';
---

<BaseLayout title="Contact — Kagasoff Law Firm, A.P.C.">
  <!-- HERO -->
  <section class="bg-navy text-paper">
    <div class="mx-auto max-w-[1180px] px-5 pb-12 pt-14 md:px-10 md:pb-[68px] md:pt-16">
      <p class="mb-5 text-xs uppercase tracking-[0.32em] text-brasslight">Contact</p>
      <h1 class="mb-4 max-w-[680px] font-serif text-[36px] font-medium leading-[1.1] md:text-[56px] md:leading-[1.06]">Tell us what happened.</h1>
      <p class="max-w-[560px] text-[16px] font-light leading-[1.7] text-mist md:text-[17px]">
        Reach out for a free, confidential consultation. We'll review your situation and tell you
        honestly how we can help.
      </p>
    </div>
  </section>

  <!-- BODY -->
  <section class="mx-auto grid max-w-[1180px] grid-cols-1 items-start gap-12 px-5 py-14 md:grid-cols-[1.4fr_1fr] md:gap-16 md:px-10 md:py-[72px]">
    <!-- FORM / CONFIRM -->
    <div>
      <form id="consult-form" novalidate>
        <h2 class="mb-1.5 font-serif text-[26px] font-medium text-navy md:text-[30px]">Request a free consultation</h2>
        <p class="mb-[30px] text-[14px] font-light text-ink">
          Fields marked <span class="text-brass">*</span> are required.
        </p>

        <div class="mb-5 grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div>
            <label class={labelCls} for="name">Name <span class="text-brass">*</span></label>
            <input class="fld" id="name" name="name" type="text" placeholder="Your full name" />
          </div>
          <div>
            <label class={labelCls} for="phone">Phone <span class="text-brass">*</span></label>
            <input class="fld" id="phone" name="phone" type="tel" placeholder="(657) 000-0000" />
          </div>
        </div>

        <div class="mb-5">
          <label class={labelCls} for="email">Email</label>
          <input class="fld" id="email" name="email" type="email" placeholder="you@email.com" />
        </div>

        <div class="mb-5">
          <label class={labelCls} for="area">Matter type</label>
          <select class="fld" id="area" name="area">
            {matterOptions.map((o) => <option value={o}>{o}</option>)}
          </select>
        </div>

        <div class="mb-6">
          <label class={labelCls} for="message">How can we help? <span class="text-brass">*</span></label>
          <textarea class="fld" id="message" name="message" placeholder="Briefly describe your situation. Do not include confidential details you wouldn't want sent by email."></textarea>
        </div>

        <div id="form-error" class="mb-5 hidden rounded-md border border-[#d8b4b4] bg-[#f7ecec] px-4 py-3 text-[13.5px] text-[#8a3838]">
          Please enter your name, a phone number, and a short message.
        </div>

        <button type="submit" class="lift inline-block rounded-[7px] bg-navy px-[30px] py-4 text-sm font-semibold tracking-[0.04em] text-paper">Submit request</button>
        <p class="mt-5 max-w-[460px] text-[12px] font-light leading-[1.6] text-ink/70">
          Submitting this form does not create an attorney–client relationship. Information sent
          through this form is not confidential until an engagement is established.
        </p>
      </form>

      <!-- Confirmation (hidden until submit) -->
      <div id="confirm-panel" class="hidden rounded-lg bg-navy px-6 py-9 text-paper md:px-11 md:py-12">
        <div class="mb-3.5 font-serif text-[26px] md:text-[34px]">Thank you, <span id="confirm-name">there</span>.</div>
        <p class="mb-2 text-[16px] font-light leading-[1.7] text-mist">
          Your message has been received. An attorney will be in touch shortly — typically within
          one business day.
        </p>
        <p class="mb-7 text-[16px] font-light leading-[1.7] text-mist">
          If your matter is urgent, please call us directly.
        </p>
        <div class="flex flex-col gap-3.5 sm:flex-row sm:flex-wrap">
          <a href="tel:6572184947" class="lift inline-block rounded-[7px] bg-brass px-[30px] py-4 text-center text-sm font-semibold tracking-[0.04em] text-navy">Call (657) 218-4947</a>
          <button type="button" id="reset-form" class="lift inline-block rounded-[7px] border border-[rgba(250,248,243,0.4)] px-[30px] py-4 text-sm font-semibold tracking-[0.04em] text-paper">Send another message</button>
        </div>
      </div>
    </div>

    <!-- INFO -->
    <div>
      <div class="mb-6 rounded-lg bg-cream px-6 py-6 md:px-[30px] md:py-8">
        <p class="mb-[18px] text-[11px] uppercase tracking-[0.22em] text-brass">Office</p>
        <div class="mb-4 font-serif text-[21px] leading-[1.4] text-navy">
          14541 Brookhurst St,<br />Suite D4<br />Westminster, CA 92683
        </div>
        <div class="text-[14px] leading-[1.9] text-ink">
          <div>Phone: <a href="tel:6572184947" class="border-b border-[#c9bfa6] text-navy">(657) 218-4947</a></div>
          <div>Hours: By appointment, Mon–Fri</div>
        </div>
      </div>
      <Placeholder label="Map — Westminster office" class="min-h-[200px] rounded-lg md:min-h-[240px]" />
    </div>
  </section>

  <script>
    // Client-side validation + confirmation state.
    // NOTE: this only SHOWS a confirmation — it does NOT deliver the message.
    // Wire delivery here: add data-netlify="true" to the <form> (Netlify Forms),
    // POST to Formspree, or handle it in an Astro API route under src/pages/api/.
    const form = document.getElementById('consult-form') as HTMLFormElement | null;
    const errorBox = document.getElementById('form-error');
    const confirmPanel = document.getElementById('confirm-panel');
    const nameOut = document.getElementById('confirm-name');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const name = (data.get('name') || '').toString().trim();
      const phone = (data.get('phone') || '').toString().trim();
      const message = (data.get('message') || '').toString().trim();

      if (name && phone && message) {
        errorBox?.classList.add('hidden');
        if (nameOut) nameOut.textContent = name.split(/\s+/)[0];
        form.style.display = 'none';
        confirmPanel?.classList.remove('hidden');
      } else {
        errorBox?.classList.remove('hidden');
      }
    });

    document.getElementById('reset-form')?.addEventListener('click', () => {
      form?.reset();
      confirmPanel?.classList.add('hidden');
      if (form) form.style.display = 'block';
    });
  </script>
</BaseLayout>
