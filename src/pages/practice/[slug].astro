---
/** Practice-area detail — ONE template → all 7 pages. Navy hero, sticky
    sidebar (all areas + a navy consultation card), the "How we can help"
    content, matter list, and the shared four-step process. */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { practiceAreas, process } from '../../data/practiceAreas';
import type { PracticeArea } from '../../data/practiceAreas';

export function getStaticPaths() {
  return practiceAreas.map((area) => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

interface Props {
  area: PracticeArea;
}

const { area } = Astro.props;
---

<BaseLayout title={`${area.name} — Kagasoff Law Firm, A.P.C.`} description={area.blurb}>
  <!-- HERO -->
  <section class="bg-navy text-paper">
    <div class="mx-auto max-w-[1180px] px-5 pb-12 pt-14 md:px-10 md:pb-[70px] md:pt-16">
      <h1 class="mb-[18px] font-serif text-[36px] font-medium leading-[1.1] md:text-[58px] md:leading-[1.05]">{area.name}</h1>
      <p class="max-w-[600px] text-[16px] font-light leading-[1.7] text-mist md:text-[17px]" set:html={area.blurb} />
    </div>
  </section>

  <!-- BODY -->
  <section class="mx-auto grid max-w-[1180px] grid-cols-1 items-start gap-12 px-5 py-14 md:grid-cols-[260px_1fr] md:gap-16 md:px-10 md:py-[72px]">
    <!-- SIDEBAR -->
    <aside class="md:sticky md:top-6">
      <p class="mb-[18px] text-[11px] uppercase tracking-[0.22em] text-brass">Practice Areas</p>
      <div class="flex flex-col">
        {
          practiceAreas.map((a) => {
            const active = a.slug === area.slug;
            return (
              <a
                href={`/practice/${a.slug}`}
                class:list={[
                  'sidelink border-l-2 px-4 py-[13px] font-serif text-[19px]',
                  active
                    ? 'border-brass bg-cream text-navy'
                    : 'border-line text-[#6f6857]',
                ]}
              >
                {a.name}
              </a>
            );
          })
        }
      </div>

      <!-- Consultation card -->
      <div class="mt-[30px] rounded-lg bg-navy text-paper" style="padding:26px 24px">
        <div class="mb-2 font-serif text-[21px]">Free consultation</div>
        <p class="mb-4 text-[13px] font-light leading-[1.6] text-mist">
          We'll review your situation and tell you honestly how we can help.
        </p>
        <a href="tel:6572184947" class="lift block rounded-[7px] bg-brass px-[22px] py-[11px] text-center text-[13px] font-semibold tracking-[0.04em] text-navy">Call (657) 218-4947</a>
      </div>
    </aside>

    <!-- CONTENT -->
    <div>
      <h2 class="mb-[18px] font-serif text-[26px] font-medium text-navy md:text-[34px]">How we can help</h2>
      {area.overview.map((p) => <p class="mb-[18px] text-[15.5px] font-light leading-[1.8] text-ink" set:html={p} />)}

      <h3 class="mb-5 mt-9 font-serif text-[22px] font-semibold text-navy md:text-[24px]" set:html={area.casesHeading} />
      <div class="mb-11 grid grid-cols-1 gap-x-8 gap-y-3 sm:grid-cols-2">
        {
          area.cases.map((c) => (
            <div class="flex items-baseline gap-3 text-[15px] text-navy">
              <span class="text-brass">—</span>
              <span set:html={c} />
            </div>
          ))
        }
      </div>

      <h3 class="mb-6 font-serif text-[24px] font-semibold text-navy">What to expect</h3>
      <div class="border-t border-line">
        {
          process.map((step, i) => (
            <div class="grid grid-cols-[54px_1fr] gap-5 border-b border-line py-[22px]">
              <div class="font-serif text-[26px] text-brass">{String(i + 1).padStart(2, '0')}</div>
              <div>
                <div class="mb-1.5 text-[16px] font-semibold text-navy" set:html={step.title} />
                <p class="text-[14px] font-light leading-[1.65] text-ink" set:html={step.body} />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy text-paper">
    <div class="mx-auto max-w-[1180px] px-5 py-14 text-center md:px-10 md:py-[70px]">
      <h2 class="mb-3.5 font-serif text-[28px] font-medium md:text-[40px]">Have a {area.name.toLowerCase()} matter?</h2>
      <p class="mb-[30px] text-[16px] font-light text-mist">Let's talk today. Your first consultation is free and confidential.</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:flex-wrap sm:justify-center">
        <a href="tel:6572184947" class="lift inline-block w-full rounded-[7px] bg-brass px-9 py-[18px] text-center text-[15px] font-semibold tracking-[0.04em] text-navy sm:w-auto">Call (657) 218-4947</a>
        <a href="/contact" class="lift inline-block w-full rounded-[7px] border border-[rgba(250,248,243,0.4)] px-9 py-[18px] text-center text-[15px] font-semibold tracking-[0.04em] text-paper sm:w-auto">Send a message</a>
      </div>
    </div>
  </section>
</BaseLayout>
