---
/** Cream call-to-action band used at the foot of content pages. */
interface Props {
  heading?: string;
  sub?: string;
}
const {
  heading = 'Tell us what happened.',
  sub = 'Consultations are free and confidential.',
} = Astro.props;
---

<section class="border-t border-[#e7e0cf] bg-cream">
  <div class="flex flex-wrap items-center justify-between gap-12 px-[clamp(24px,5vw,72px)] py-[60px]">
    <div>
      <h2 class="mb-2 font-serif text-[40px] font-medium text-navy">{heading}</h2>
      <p class="text-base font-light text-ink">{sub}</p>
    </div>
    <div class="flex gap-4">
      <a
        href="tel:6572184947"
        class="lift rounded-[7px] bg-navy px-[30px] py-4 text-sm font-semibold tracking-[0.04em] text-paper"
        >Call (657) 218-4947</a
      >
      <a
        href="/contact"
        class="lift rounded-[7px] border border-navy px-[30px] py-4 text-sm font-medium tracking-[0.04em] text-navy"
        >Send a message</a
      >
    </div>
  </div>
</section>
