---
/** Cream call-to-action band used at the foot of content pages. */
interface Props {
  heading?: string;
  sub?: string;
}
const {
  heading = 'Tell us what happened.',
  sub = 'Consultations are free and confidential.',
} = Astro.props;
---

<section class="relative overflow-hidden bg-cream">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brass/60 to-transparent"></div>

  <div class="flex flex-wrap items-center justify-between gap-10 px-[clamp(24px,5vw,72px)] py-[72px]">

    <!-- Left: text -->
    <div>
      <p class="mb-2.5 text-[11px] uppercase tracking-[0.36em] text-brass">Free Initial Consultation</p>
      <h2 class="mb-2 font-serif text-[44px] font-medium leading-[1.05] text-navy">{heading}</h2>
      <p class="text-[15px] font-light leading-[1.75] text-ink">{sub}</p>
    </div>

    <!-- Right: CTAs -->
    <div class="flex flex-wrap items-stretch gap-3">
      <!-- Phone — primary -->
      <a
        href="tel:6572184947"
        class="lift flex flex-col justify-center gap-[2px] rounded-[8px] bg-brass px-8 py-[16px]"
      >
        <span class="text-[10px] uppercase tracking-[0.22em] text-navy/60">Call the firm</span>
        <span class="font-serif text-[21px] tracking-[0.02em] text-navy">(657) 218-4947</span>
      </a>

      <!-- Message — secondary -->
      <a
        href="/contact"
        class="lift flex items-center rounded-[8px] border border-navy/40 px-8 py-[16px] text-[13.5px] font-medium tracking-[0.06em] text-navy transition-colors hover:border-navy/70"
      >
        Send a message
      </a>
    </div>

  </div>
</section>
