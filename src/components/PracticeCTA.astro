---
/** Cream call-to-action band used at the foot of content pages. */
interface Props {
  heading?: string;
  sub?: string;
}
const {
  heading = 'Tell us what happened.',
  sub = 'Consultations are free and confidential.',
} = Astro.props;
---

<section class="relative overflow-hidden bg-cream">
  <!-- top accent gradient -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brass/60 to-transparent"></div>

  <div class="mx-auto max-w-[1180px] px-[clamp(24px,5vw,72px)] py-[88px]">
    <div class="flex flex-col items-center text-center">

      <p class="mb-4 text-[11px] uppercase tracking-[0.36em] text-brass">Free Initial Consultation</p>

      <h2 class="mb-4 font-serif text-[50px] font-medium leading-[1.05] text-navy">
        {heading}
      </h2>

      <div class="mb-6 h-px w-12 bg-brass opacity-50"></div>

      <p class="mb-10 max-w-[440px] text-[15px] font-light leading-[1.75] text-ink">{sub}</p>

      <!-- CTA row -->
      <div class="flex flex-col items-center gap-3 sm:flex-row sm:items-stretch">
        <!-- Phone — primary, stacked label + number -->
        <a
          href="tel:6572184947"
          class="lift group flex flex-col items-center justify-center gap-[3px] rounded-[8px] bg-navy px-9 py-[18px] min-w-[220px]"
        >
          <span class="text-[10px] uppercase tracking-[0.22em] text-gold/60">Call the firm</span>
          <span class="font-serif text-[22px] tracking-[0.02em] text-paper">(657) 218-4947</span>
        </a>

        <!-- Divider (desktop only) -->
        <div class="hidden h-auto w-px bg-navy/12 sm:block"></div>

        <!-- Message — secondary ghost -->
        <a
          href="/contact"
          class="lift flex items-center justify-center rounded-[8px] border border-navy/25 px-9 py-[18px] text-[13.5px] font-medium tracking-[0.06em] text-navy transition-colors hover:border-navy/50 min-w-[180px]"
        >
          Send a message
        </a>
      </div>

    </div>
  </div>
</section>
