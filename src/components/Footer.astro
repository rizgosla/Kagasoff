---
import { practiceAreas } from '../data/practiceAreas';

const primary = practiceAreas.slice(0, 4);
const secondary = practiceAreas.slice(4);
---

<footer class="bg-navydark text-slate">
  <div class="grid grid-cols-1 gap-12 px-[clamp(24px,5vw,72px)] pb-[30px] pt-14 md:grid-cols-[1.4fr_1fr_1fr]">
    <div>
      <div class="mb-1.5 font-serif text-[22px] text-paper">Kagasoff Law Firm, A.P.C.</div>
      <div class="text-[13px] leading-[1.7]">
        14541 Brookhurst St, Suite D4<br />Westminster, CA 92683
      </div>
      <div class="mt-2.5 text-[13px] leading-[1.7]">
        Office: <a href="tel:6572184947" class="text-gold">(657) 218-4947</a>
      </div>
    </div>

    <div>
      <div class="mb-3.5 text-[11px] uppercase tracking-[0.2em] text-brass">Practice</div>
      <div class="flex flex-col gap-[9px] text-[13px]">
        {
          primary.map((a) => (
            <a href={`/practice/${a.slug}`} class="opacity-80 transition-opacity hover:opacity-100">
              {a.name}
            </a>
          ))
        }
      </div>
    </div>

    <div>
      <div class="mb-3.5 text-[11px] uppercase tracking-[0.2em] text-brass">Firm</div>
      <div class="flex flex-col gap-[9px] text-[13px]">
        <a href="/about" class="opacity-80 transition-opacity hover:opacity-100">About</a>
        <a href="/contact" class="opacity-80 transition-opacity hover:opacity-100">Contact</a>
        {
          secondary.map((a) => (
            <a href={`/practice/${a.slug}`} class="opacity-80 transition-opacity hover:opacity-100">
              {a.name}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div class="mx-[clamp(24px,5vw,72px)] flex flex-col justify-between gap-2 border-t border-paper/10 pb-10 pt-[18px] text-[11.5px] sm:flex-row">
    <span>© {new Date().getFullYear()} Kagasoff Law Firm, A.P.C. All rights reserved.</span>
    <span>Attorney advertising. Prior results do not guarantee a similar outcome.</span>
  </div>
</footer>
