---
/** Full-width navy-dark footer: brand column with address + phone, practice
    and firm link columns, disclaimer bottom bar. Thin brass gradient rule on top. */
import { practiceAreas } from '../data/practiceAreas';

const primary = practiceAreas.slice(0, 4);
const secondary = practiceAreas.slice(4);
const year = new Date().getFullYear();
---

<footer class="bg-navydark text-slate">
  <div class="h-px bg-gradient-to-r from-transparent via-brass/40 to-transparent"></div>

  <div class="mx-auto max-w-[1180px] px-10 pb-8 pt-14">
    <div class="grid grid-cols-[1.6fr_1fr_1fr] gap-12">
      <!-- Brand -->
      <div>
        <div class="mb-1 flex items-center gap-3">
          <span class="h-[26px] w-0.5 shrink-0 bg-brass"></span>
          <span class="font-serif text-[21px] leading-[1.3] text-paper">Kagasoff Law Firm, A.P.C.</span>
        </div>
        <div class="mt-3 text-[12.5px] leading-[1.85] text-slate/70">
          14541 Brookhurst St, Suite D4<br />
          Westminster, CA 92683
        </div>
        <a href="tel:6572184947" class="mt-3 inline-flex items-center gap-2 text-[12.5px] text-gold/80">
          <span class="inline-block h-px w-4 bg-gold/40"></span>
          (657) 218-4947
        </a>
      </div>

      <!-- Practice -->
      <div>
        <div class="mb-4 text-[10.5px] uppercase tracking-[0.22em] text-brass/80">Practice</div>
        <div class="flex flex-col gap-2.5">
          {
            primary.map((p) => (
              <a href={`/practice/${p.slug}`} class="text-[12.5px] text-slate/70 transition-colors hover:text-paper">
                {p.name}
              </a>
            ))
          }
        </div>
      </div>

      <!-- Firm -->
      <div>
        <div class="mb-4 text-[10.5px] uppercase tracking-[0.22em] text-brass/80">Firm</div>
        <div class="flex flex-col gap-2.5">
          <a href="/about" class="text-[12.5px] text-slate/70 transition-colors hover:text-paper">About</a>
          <a href="/contact" class="text-[12.5px] text-slate/70 transition-colors hover:text-paper">Contact</a>
          {
            secondary.map((p) => (
              <a href={`/practice/${p.slug}`} class="text-[12.5px] text-slate/70 transition-colors hover:text-paper">
                {p.name}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="mt-12 flex flex-wrap justify-between gap-2 border-t border-paper/10 pt-5 text-[11px] text-slate/50">
      <span>© {year} Kagasoff Law Firm, A.P.C. All rights reserved.</span>
      <span>Attorney advertising. Prior results do not guarantee a similar outcome.</span>
    </div>
  </div>
</footer>
